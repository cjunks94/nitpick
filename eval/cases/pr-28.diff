index f6c4823..793228c 100644
--- a/src/agentic_portfolio/web/static/style.css
+++ b/src/agentic_portfolio/web/static/style.css
@@ -70,6 +70,20 @@ a:hover { color: var(--amber-bright); }
     margin-bottom: 12px;
 }
 
+/* Three low-density panels (Run Progress, Watchlist, System) tile across
+   the bottom; gap replaces the per-panel margin so the row sits flush. */
+.panel-grid-3 {
+    display: grid;
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+    gap: 12px;
+    margin-bottom: 12px;
+}
+
+.panel-grid-3 .panel {
+    margin-bottom: 0;
+    min-width: 0;
+}
+
 .panel-title {
     background: var(--bg);
     color: var(--amber);
@@ -373,4 +387,6 @@ button.run-now:disabled {
     .panel-body { overflow-x: auto; }
     table.data { width: max-content; min-width: 100%; }
     table.data td, table.data th { white-space: nowrap; }
+
+    .panel-grid-3 { grid-template-columns: 1fr; gap: 12px; }
 }
