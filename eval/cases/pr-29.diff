+def _make_broker(request: Request) -> PaperBroker:
+    """Construct the broker for an order placement.
+
+    Today this always returns a PaperBroker. The seam exists so that a
+    future LiveBroker addition has a single, audited point of selection
+    instead of being threaded through every call site. The contract for
+    that future work is: when `app.state.demo_mode` is True (the default
+    and fail-safe), this MUST return a paper broker. A real broker may
+    only be returned when demo_mode is explicitly False.
+    """
+    from ..broker import PaperBroker
+    from ..portfolio import Portfolio
+
+    paths = _data_paths(request)
+    portfolio = Portfolio.load(paths["portfolio"])
+    return PaperBroker(portfolio, paths["orders"])
