# nitpick serve — env vars for Railway / Fly / any container host.
# Copy to .env for local testing (and ensure .env is in .gitignore — it is).

# LLM provider key. Required.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub App identity. Required.
# - GITHUB_APP_ID: shown on your App's Settings page (numeric).
# - GITHUB_APP_PRIVATE_KEY: PEM contents from "Generate a private key" on the
#   App's Settings page. Multi-line; include the -----BEGIN/END----- delimiters.
#   On Railway, paste the full multi-line PEM into the variable value field.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEowIBAAKC...
-----END RSA PRIVATE KEY-----"

# Webhook signature secret. Required. Set this string both here AND in the
# App's webhook configuration ("Webhook secret" field). Use a long random
# value (e.g. `openssl rand -hex 32`).
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Optional: override the default Anthropic model. Default is claude-haiku-4-5
# (best $/F1 ratio). Use claude-sonnet-4-6 for higher precision at ~4x cost.
# NITPICK_MODEL=claude-sonnet-4-6

# Optional: bind port. Defaults to 8080 locally. Railway sets PORT for you.
# PORT=8080
